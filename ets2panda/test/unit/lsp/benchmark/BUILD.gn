import("//arkcompiler/ets_frontend/test_helper.gni")

config("lsp_benchmark_config") {
  # Use an absolute host path so benchmarks can be run from any working directory.
  cases_dir = get_path_info(
          "//arkcompiler/ets_frontend/ets2panda/test/unit/lsp/benchmark/cases",
          "abspath")

  # internal_api::Initializer uses BUILD_FOLDER to resolve $ORIGIN/arktsconfig.json.
  # For host benchmarks under GN, point it to the host frontend output directory.
  benchmark_build_folder =
      get_path_info("$root_out_dir/arkcompiler/ets_frontend", "abspath")
  defines = [
    "CASES_DIR=\"$cases_dir\"",
    "BUILD_FOLDER=\"$benchmark_build_folder\"",
  ]
  include_dirs = [
    "${root_gen_dir}/arkcompiler/ets_frontend/ets2panda",
    "//arkcompiler/runtime_core/static_core/assembler",
    "${root_gen_dir}/arkcompiler/runtime_core/static_core/assembler",
  ]
  if (current_toolchain != default_toolchain) {
    include_dirs += [
      "$root_out_dir/../gen/arkcompiler/ets_frontend/ets2panda",
      "$root_out_dir/../gen/arkcompiler/runtime_core/static_core/assembler",
    ]
  }
}

template("ets2panda_lsp_benchmark_unittest") {
  host_unittest_action(target_name) {
    use_exceptions = true
    testonly = true
    sources = invoker.sources + [ "src/lspMemoryManager.cpp" ]

    configs = [
      "//build/config/components/runtime_core/static_core:ark_common_config",
      "//arkcompiler/ets_frontend/ets2panda:libes2panda_public_config",
      "//arkcompiler/ets_frontend/ets2panda:libes2panda_config",
    ]
    if (defined(invoker.configs)) {
      configs += invoker.configs
    }

    include_dirs = [
      "//arkcompiler/ets_frontend/ets2panda",
      "${target_out_dir}",
    ]
    if (defined(invoker.include_dirs)) {
      include_dirs += invoker.include_dirs
    }

    if (defined(invoker.deps)) {
      deps = invoker.deps
    }

    if (defined(invoker.external_deps)) {
      external_deps = invoker.external_deps
    } else {
      external_deps = [
        "googletest:gtest_main",
        "icu:static_icuuc",
        "json:nlohmann_json_static",
        "runtime_core:arkabc2program_public_headers",
        "runtime_core:arkassembler_public_headers",
        "runtime_core:arkbase_public_headers",
        "runtime_core:arkfile_public_headers",
        "runtime_core:libpandabase_headers",
        sdk_libc_secshared_dep,
      ]
    }

    module_out_path = "arkcompiler/ets_frontend"
  }
}

