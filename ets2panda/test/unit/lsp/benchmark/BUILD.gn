lsp_benchmark_target_configs = [
  "//arkcompiler/ets_frontend/ets2panda/lsp:libes2panda_lsp_config",
  ":lsp_benchmark_config",
]

lsp_benchmark_target_include_dirs = [
  "include",
  "../benchmark",
  "../../../../lsp/include",
  "../../../../public",
  "../../../../",
]

lsp_benchmark_target_deps = [
  "//arkcompiler/ets_frontend/ets2panda/lsp:libes2panda_lsp_static",
  "//third_party/benchmark:benchmark",
]

group("lsp_benchmark") {
  testonly = true
  deps = []
  foreach(test_case, lsp_benchmark_test_cases) {
    deps += [ ":${test_case.name}" ]
  }
}

foreach(test_case, lsp_benchmark_test_cases) {
  ets2panda_lsp_benchmark_unittest(test_case.name) {
    sources = [ test_case.source ]
    configs = lsp_benchmark_target_configs
    include_dirs = lsp_benchmark_target_include_dirs
    deps = lsp_benchmark_target_deps
  }
}
