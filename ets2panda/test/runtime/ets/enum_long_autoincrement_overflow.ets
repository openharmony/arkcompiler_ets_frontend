// Auto-increment past INT32_MAX for :long enum
enum LongEnumAutoIncrementPastInt32Max: long {
    first = 0x7fffffff - 1,
    second,
    third
}

// All members auto-generated from zero for :long enum
enum LongEnumAllAutoGenerated: long {
    zero,
    one,
    two
}

// Auto-increment from INT32_MAX boundary for :long enum
enum LongEnumFromInt32Max: long {
    first = 0x7fffffff,
    second,
    third
}

// Mixed explicit and auto-generated values for :long enum
enum LongEnumMixed: long {
    neg = -1,
    zero,
    pos = 1,
    posNext,
    large = 0x7fffffff,
    afterLarge
}

// Long enum with negative boundary auto-increment
enum LongEnumNegativeBoundary: long {
    min = -2147483649,
    nextAfterMin,
    mid = -1,
    zero,
    one
}

function main(): void {
    // LongEnumAutoIncrementPastInt32Max
    arktest.assertEQ(LongEnumAutoIncrementPastInt32Max.first.valueOf(), 0x7ffffffe)
    arktest.assertEQ(LongEnumAutoIncrementPastInt32Max.second.valueOf(), 0x7fffffff)
    arktest.assertEQ(LongEnumAutoIncrementPastInt32Max.third.valueOf(), 2147483648)

    // LongEnumAllAutoGenerated
    arktest.assertEQ(LongEnumAllAutoGenerated.zero.valueOf(), 0)
    arktest.assertEQ(LongEnumAllAutoGenerated.one.valueOf(), 1)
    arktest.assertEQ(LongEnumAllAutoGenerated.two.valueOf(), 2)

    // LongEnumFromInt32Max
    arktest.assertEQ(LongEnumFromInt32Max.first.valueOf(), 2147483647)
    arktest.assertEQ(LongEnumFromInt32Max.second.valueOf(), 2147483648)
    arktest.assertEQ(LongEnumFromInt32Max.third.valueOf(), 2147483649)

    // LongEnumMixed
    arktest.assertEQ(LongEnumMixed.neg.valueOf(), -1)
    arktest.assertEQ(LongEnumMixed.zero.valueOf(), 0)
    arktest.assertEQ(LongEnumMixed.pos.valueOf(), 1)
    arktest.assertEQ(LongEnumMixed.posNext.valueOf(), 2)
    arktest.assertEQ(LongEnumMixed.large.valueOf(), 2147483647)
    arktest.assertEQ(LongEnumMixed.afterLarge.valueOf(), 2147483648)

    // LongEnumNegativeBoundary
    arktest.assertEQ(LongEnumNegativeBoundary.min.valueOf(), -2147483649)
    arktest.assertEQ(LongEnumNegativeBoundary.nextAfterMin.valueOf(), -2147483648)
    arktest.assertEQ(LongEnumNegativeBoundary.mid.valueOf(), -1)
    arktest.assertEQ(LongEnumNegativeBoundary.zero.valueOf(), 0)
    arktest.assertEQ(LongEnumNegativeBoundary.one.valueOf(), 1)
}
